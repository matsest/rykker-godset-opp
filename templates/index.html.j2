<!DOCTYPE html>
<html lang="nb">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Rykker Godset Opp? – Følg Strømsgodsets vei tilbake til Eliteserien</title>
    <meta name="description" content="Oppdaterte nøkkeltall, opprykksstatus, ligastatistikk og tabell for Strømsgodset i 2026.">
    <meta name="keywords" content="Strømsgodset, Godset, OBOS-ligaen, opprykk, Eliteserien, tabell, fotball, 2026">
    <meta name="author" content="Mats Estensen">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://godset.mats.codes/">
    <link rel="icon" type="image/svg+xml" href="favicon.svg">
    <link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png">
    <link rel="manifest" href="manifest.json">
    <meta name="apple-mobile-web-app-title" content="Godset Opp?">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="stylesheet" href="style.css">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://godset.mats.codes/">
    <meta property="og:title" content="Rykker Godset Opp? Følg Strømsgodsets vei tilbake til Eliteserien.">
    <meta property="og:description" content="Oppdaterte nøkkeltall, opprykksstatus, ligastatistikk og tabell for Strømsgodset i 2026.">
    <meta property="og:locale" content="nb_NO">
    <meta property="og:image" content="https://godset.mats.codes/og-image.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@matsest">
    <meta name="twitter:creator" content="@matsest">
    <meta name="twitter:url" content="https://godset.mats.codes/">
    <meta name="twitter:title" content="Rykker Godset Opp? Følg Strømsgodsets vei tilbake til Eliteserien.">
    <meta name="twitter:description" content="Oppdaterte nøkkeltall, opprykksstatus, ligastatistikk og tabell for Strømsgodset i 2026.">
    <meta name="twitter:image" content="https://godset.mats.codes/og-image.png">

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Rykker Godset Opp?",
        "url": "https://godset.mats.codes/",
        "description": "Følg Strømsgodsets vei tilbake til Eliteserien. Oppdatert statistikk, opprykksstatus, tabell, form og kommende kamper i OBOS-ligaen 2026.",
        "inLanguage": "nb",
        "publisher": {
            "@type": "Person",
            "name": "Mats Estensen",
            "url": "https://github.com/matsest"
        }
    }
    </script>
</head>
<body>
    <a href="#main-content" class="skip-link">Hopp til innhold</a>

    <header class="site-header">
        <div class="container">
            <h1 class="site-title">Rykker Godset Opp?</h1>
            <p class="site-subtitle">Følg Strømsgodsets vei tilbake til Eliteserien i 2026.<br>Automatisk oppdatert med statistikk og tall daglig.</p>
        </div>
    </header>

    <nav class="site-nav" aria-label="Seksjoner">
        <div class="nav-inner">
            <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" type="button">
                <span class="sr-only">Meny</span>
                <svg class="icon-menu" viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                    <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <line x1="3" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <line x1="3" y1="18" x2="21" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <svg class="icon-close" viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                    <line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <line x1="6" y1="18" x2="18" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </button>
            <div class="nav-menu" id="nav-menu">
                <a href="#opprykksstatus">Opprykksstatus</a>
                <a href="#nokkeltall">Nøkkeltall</a>
                <a href="#ligastatistikk">Ligastatistikk</a>
                <a href="#form">Form</a>
                <a href="#siste-resultater">Resultater</a>
                <a href="#kommende-kamper">Kamper</a>
                <a href="#toppscorer">Målpoeng</a>
                <a href="#maltidspunkt">Måltidspunkt</a>
                <a href="#tabell">Tabell</a>
            </div>
        </div>
    </nav>

    <main id="main-content" class="container">
        {# Hero: The Gauge #}
        <section class="hero">
            <div class="gauge">
                <div class="gauge-bar">
                    <div class="gauge-needle" style="left: {{ team.promotion.gauge_percent }}%"></div>
                </div>
                <div class="gauge-labels">
                    <span>Nei</span>
                    <span>Tja</span>
                    <span>Ja!</span>
                </div>
            </div>
            <div class="hero-stats">
                <div class="hero-stat">
                    <span class="hero-stat-value">{{ team.position }}.</span>
                    <span class="hero-stat-label">Plass</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-value">{{ team.points }}</span>
                    <span class="hero-stat-label">Poeng</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-value">{{ team.played }}</span>
                    <span class="hero-stat-label">Kamper spilt</span>
                </div>
            </div>
        </section>

        {# Promotion Status #}
        <section class="section" id="opprykksstatus">
            <h2 class="section-title"><a href="#opprykksstatus">Opprykksstatus</a></h2>
            <div class="promo-grid promo-grid-3">
                <div class="promo-item {% set diff_1st = -team.promotion.points_to_1st %}{% if diff_1st >= 0 and team.position <= 1 %}promo-positive{% elif diff_1st >= -3 %}promo-warning{% else %}promo-negative{% endif %}">
                    <span class="promo-value">{% set diff_1st = -team.promotion.points_to_1st %}{% if diff_1st > 0 %}+{% endif %}{{ diff_1st|abs }}</span>
                    <span class="promo-label">Poeng unna 1. plass</span>
                </div>
                <div class="promo-item {% set diff_2nd = -team.promotion.points_to_2nd %}{% if diff_2nd >= 0 and team.position <= 2 %}promo-positive{% elif diff_2nd >= -3 %}promo-warning{% else %}promo-negative{% endif %}">
                    <span class="promo-value">{% set diff_2nd = -team.promotion.points_to_2nd %}{% if diff_2nd > 0 %}+{% endif %}{{ diff_2nd|abs }}</span>
                    <span class="promo-label">Poeng unna 2. plass</span>
                </div>
                <div class="promo-item {% set diff_6th = -team.promotion.points_to_6th %}{% if diff_6th >= 0 and team.position <= 6 %}promo-positive{% elif diff_6th >= -3 %}promo-warning{% else %}promo-negative{% endif %}">
                    <span class="promo-value">{% set diff_6th = -team.promotion.points_to_6th %}{% if diff_6th > 0 %}+{% endif %}{{ diff_6th|abs }}</span>
                    <span class="promo-label">Poeng unna 6. plass (kvalik)</span>
                </div>
            </div>
        </section>

        {# Key Numbers #}
        <section class="section" id="nokkeltall">
            <h2 class="section-title"><a href="#nokkeltall">Nøkkeltall</a></h2>
            <div class="stats-grid">
                <div class="stat-card {% if team.points_per_game >= 1.93 %}stat-positive{% elif team.points_per_game >= 1.53 %}stat-warning{% else %}stat-negative{% endif %}">
                    <span class="stat-value">{{ team.won }}-{{ team.drawn }}-{{ team.lost }}</span>
                    <span class="stat-label">
                        Seire – Uavgjort – Tap
                        <span class="tooltip-trigger" tabindex="0">&#9432;
                            <span class="tooltip-text">Grønn: ≥1,93 poeng/kamp, Gul: ≥1,53 poeng/kamp, Rød: &lt;1,53</span>
                        </span>
                    </span>
                </div>
                <div class="stat-card {% if team.played > 0 %}{% set win_pct = (team.won / team.played * 100) %}{% if win_pct >= 58 %}stat-positive{% elif win_pct >= 42 %}stat-warning{% else %}stat-negative{% endif %}{% endif %}">
                    <span class="stat-value">{% if team.played > 0 %}{{ (team.won / team.played * 100)|round|int }}%{% else %}0%{% endif %}</span>
                    <span class="stat-label">
                        Seiersprosent
                        <span class="tooltip-trigger" tabindex="0">&#9432;
                            <span class="tooltip-text">Grønn: ≥58% seier, Gul: ≥42% seier, Rød: &lt;42% seier</span>
                        </span>
                    </span>
                </div>
                <div class="stat-card {% if team.points_per_game >= 1.93 %}stat-positive{% elif team.points_per_game >= 1.53 %}stat-warning{% else %}stat-negative{% endif %}">
                    <span class="stat-value">{{ team.points_per_game }}</span>
                    <span class="stat-label">
                        Poeng per kamp
                        <span class="tooltip-trigger" tabindex="0">&#9432;
                            <span class="tooltip-text">Grønn: ≥1,93, Gul: ≥1,53, Rød: &lt;1,53</span>
                        </span>
                    </span>
                </div>
            </div>
            <p class="stats-note">Skalaen er basert på gjennomsnittlig poengbehov for direkte opprykk (~58 poeng) og kvalikplass (~46 poeng) i OBOS-ligaen de siste fem sesongene.</p>
        </section>

        {# League Stats #}
        {% if team.ranks %}
        <section class="section" id="ligastatistikk">
            <h2 class="section-title"><a href="#ligastatistikk">Ligastatistikk</a></h2>
            <p class="section-intro">Viser hvor Godset ligger på ulike statistikker sammenlignet med resten av ligaen, og om laget presterer bedre eller dårligere enn tabellplasseringen skulle tilsi.</p>
            {% for category_key, category in team.ranks.items() %}
            <div class="stats-category">
                <h3 class="stats-category-title">{{ category.label }}</h3>
                <div class="stats-grid">
                    {% for key, rank in category.stats.items() %}
                    <div class="stat-card {% if rank.vs_table == 'better' %}stat-positive{% elif rank.vs_table == 'worse' %}stat-negative{% else %}stat-neutral{% endif %} tier-{{ rank.vs_table_tier|default(0) }}">
                        <span class="stat-value">{{ rank.display_value }}</span>
                        <span class="stat-label">
                            {{ rank.label }}
                            {% if key == 'points_last_5' %}
                            <span class="tooltip-trigger" tabindex="0" aria-label="Hva er form?">&#9432;
                                <span class="tooltip-text">Poeng fra de siste 5 kampene (maks 15 poeng)</span>
                            </span>
                            {% elif key == 'goals_scored' %}
                            <span class="tooltip-trigger" tabindex="0" aria-label="Hva betyr dette?">&#9432;
                                <span class="tooltip-text">Snitt mål scoret per kamp – høyere er bedre</span>
                            </span>
                            {% elif key == 'total_shots' %}
                            <span class="tooltip-trigger" tabindex="0" aria-label="Hva betyr dette?">&#9432;
                                <span class="tooltip-text">Snitt skudd per kamp – høyere er bedre</span>
                            </span>
                            {% elif key == 'shots_on_goal' %}
                            <span class="tooltip-trigger" tabindex="0" aria-label="Hva betyr dette?">&#9432;
                                <span class="tooltip-text">Snitt skudd på mål per kamp – høyere er bedre</span>
                            </span>
                            {% elif key == 'chances' %}
                            <span class="tooltip-trigger" tabindex="0" aria-label="Hva betyr dette?">&#9432;
                                <span class="tooltip-text">Snitt klare målsjanser skapt per kamp – høyere er bedre</span>
                            </span>
                            {% elif key == 'chance_conversion' %}
                            <span class="tooltip-trigger" tabindex="0" aria-label="Hva er sjanseomsetning?">&#9432;
                                <span class="tooltip-text">Andel av klare målsjanser som ender i mål – høyere er bedre</span>
                            </span>
                            {% elif key == 'goal_difference' %}
                            <span class="tooltip-trigger" tabindex="0" aria-label="Hva betyr dette?">&#9432;
                                <span class="tooltip-text">Mål scoret minus mål sluppet inn – høyere er bedre</span>
                            </span>
                            {% elif key == 'possession' %}
                            <span class="tooltip-trigger" tabindex="0" aria-label="Hva betyr dette?">&#9432;
                                <span class="tooltip-text">Andel av kampen laget har ballen – høyere er bedre</span>
                            </span>
                            {% elif key == 'goals_conceded' %}
                            <span class="tooltip-trigger" tabindex="0" aria-label="Hva betyr dette?">&#9432;
                                <span class="tooltip-text">Snitt mål sluppet inn per kamp – lavere er bedre</span>
                            </span>
                            {% elif key == 'clean_sheets' %}
                            <span class="tooltip-trigger" tabindex="0" aria-label="Hva er clean sheet?">&#9432;
                                <span class="tooltip-text">Andel kamper uten baklengsmål – høyere er bedre</span>
                            </span>
                        {% elif key == 'low_conceded' %}
                        <span class="tooltip-trigger" tabindex="0" aria-label="Hva betyr dette?">&#9432;
                            <span class="tooltip-text">Andel kamper med 0 eller 1 baklengsmål – høyere er bedre</span>
                        </span>
                        {% elif key == 'total_shots_against' %}
                        <span class="tooltip-trigger" tabindex="0" aria-label="Hva betyr dette?">&#9432;
                            <span class="tooltip-text">Snitt skudd mot laget per kamp – lavere er bedre</span>
                        </span>
                        {% elif key == 'shots_on_goal_against' %}
                        <span class="tooltip-trigger" tabindex="0" aria-label="Hva betyr dette?">&#9432;
                            <span class="tooltip-text">Snitt skudd på mål mot laget per kamp – lavere er bedre</span>
                        </span>
                        {% elif key == 'chances_against' %}
                        <span class="tooltip-trigger" tabindex="0" aria-label="Hva betyr dette?">&#9432;
                            <span class="tooltip-text">Snitt klare målsjanser motstanderen skaper mot laget per kamp – lavere er bedre</span>
                        </span>
                        {% elif key == 'points_per_game' %}
                        <span class="tooltip-trigger" tabindex="0" aria-label="Hva er poeng per kamp?">&#9432;
                            <span class="tooltip-text">Snitt poeng per kamp – høyere er bedre</span>
                        </span>
                        {% elif key == 'first_goal_pct' %}
                        <span class="tooltip-trigger" tabindex="0" aria-label="Hva er førstemål?">&#9432;
                            <span class="tooltip-text">Andel kamper laget scorer først – høyere er bedre</span>
                        </span>
                        {% elif key == 'win_when_first_pct' %}
                        <span class="tooltip-trigger" tabindex="0" aria-label="Hva er seier ved førstemål?">&#9432;
                            <span class="tooltip-text">Andel kamper vunnet etter å ha scoret først – høyere er bedre</span>
                        </span>
                        {% elif key == 'conceded_first_pct' %}
                        <span class="tooltip-trigger" tabindex="0" aria-label="Hva er baklengs først?">&#9432;
                            <span class="tooltip-text">Andel kamper laget slipper inn først – lavere er bedre</span>
                        </span>
                        {% elif key == 'win_when_conceded_pct' %}
                        <span class="tooltip-trigger" tabindex="0" aria-label="Hva er seier ved baklengs først?">&#9432;
                            <span class="tooltip-text">Andel kamper vunnet etter å ha sluppet inn først – høyere er bedre</span>
                        </span>
                        {% elif key == 'home_avg' %}
                        <span class="tooltip-trigger" tabindex="0" aria-label="Hva er poengsnitt hjemme?">&#9432;
                            <span class="tooltip-text">Snitt poeng per hjemmekamp – høyere er bedre</span>
                        </span>
                        {% elif key == 'away_avg' %}
                        <span class="tooltip-trigger" tabindex="0" aria-label="Hva er poengsnitt borte?">&#9432;
                            <span class="tooltip-text">Snitt poeng per bortekamp – høyere er bedre</span>
                        </span>
                        {% endif %}
                        </span>
                        {% if rank.full_table %}
                        <button type="button" class="stat-rank rank-btn" id="rank-btn-{{ category_key }}-{{ key }}" aria-haspopup="dialog" aria-controls="modal-{{ category_key }}-{{ key }}">
                        {% else %}
                        <span class="stat-rank">
                        {% endif %}
                            {{ rank.display_rank }}
                            <span class="rank-indicator ind-{{ rank.vs_table }} tier-{{ rank.vs_table_tier|default(0) }}">
                                {% if rank.vs_table == 'better' %}{% if rank.vs_table_tier|default(0) >= 3 %}▲▲{% else %}▲{% endif %}{% elif rank.vs_table == 'worse' %}{% if rank.vs_table_tier|default(0) >= 3 %}▼▼{% else %}▼{% endif %}{% else %}▶{% endif %}
                            </span>
                        {% if rank.full_table %}
                        </button>
                        {% else %}
                        </span>
                        {% endif %}
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </section>
        {% endif %}

        {# Form #}
        <section class="section" id="form">
            <h2 class="section-title"><a href="#form">Form siste {{ team.form_last_5|length }} kamper</a></h2>
            <div class="stats-grid">
                <div class="stat-card {% if team.points_avg_last_5 >= 1.93 %}stat-positive{% elif team.points_avg_last_5 >= 1.53 %}stat-warning{% else %}stat-negative{% endif %}">
                    <span class="stat-value">{{ team.won_last_5 }}-{{ team.drawn_last_5 }}-{{ team.lost_last_5 }}</span>
                    <span class="stat-label">
                        Seire – Uavgjort – Tap
                        <span class="tooltip-trigger" tabindex="0">&#9432;
                            <span class="tooltip-text">Grønn: ≥1,93 poeng/kamp, Gul: ≥1,53 poeng/kamp, Rød: &lt;1,53</span>
                        </span>
                    </span>
                </div>
                <div class="stat-card {% if team.points_avg_last_5 >= 1.93 %}stat-positive{% elif team.points_avg_last_5 >= 1.53 %}stat-warning{% else %}stat-negative{% endif %}">
                    <span class="stat-value">{{ team.points_avg_last_5 }}</span>
                    <span class="stat-label">
                        Poeng per kamp
                        <span class="tooltip-trigger" tabindex="0">&#9432;
                            <span class="tooltip-text">Grønn: ≥1,93, Gul: ≥1,53, Rød: &lt;1,53</span>
                        </span>
                    </span>
                </div>
                <div class="stat-card {% if team.goal_difference_last_5 > 0 %}stat-positive{% elif team.goal_difference_last_5 == 0 %}stat-warning{% else %}stat-negative{% endif %}">
                    <span class="stat-value">{% if team.goal_difference_last_5 > 0 %}+{% endif %}{{ team.goal_difference_last_5|default(0, true) }}</span>
                    <span class="stat-label">
                        Målforskjell
                        <span class="tooltip-trigger" tabindex="0">&#9432;
                            <span class="tooltip-text">Grønn: Positiv, Gul: Null, Rød: Negativ</span>
                        </span>
                    </span>
                </div>
            </div>
            <div class="form-row">
                {% for m in last_matches %}
                <button type="button" class="form-item match-btn" aria-haspopup="dialog" aria-controls="modal-match-{{ loop.index }}">
                    <span class="form-badge form-{{ m.result|lower }}">
                        {% if m.result == 'W' %}V{% elif m.result == 'D' %}U{% else %}T{% endif %}
                    </span>
                    <span class="form-venue">{% if m.is_home %}H{% else %}B{% endif %}</span>
                </button>
                {% endfor %}
            </div>
            <p class="form-points">{{ team.points_last_5 }} poeng av 15 mulige</p>
        </section>

        {# Last Matches #}
        <section class="section" id="siste-resultater">
            <h2 class="section-title"><a href="#siste-resultater">Siste resultater</a></h2>
            <div class="matches-list">
                {% for m in last_matches %}
                <button type="button" class="match-row match-{{ m.result|lower }} match-btn" aria-haspopup="dialog" aria-controls="modal-match-{{ loop.index }}">
                    <span class="match-date">{{ m.date[:10] }}</span>
                    <span class="match-teams">
                        {% if m.is_home %}{{ m.away_team }}{% else %}{{ m.home_team }}{% endif %}
                        <span class="match-venue">{% if m.is_home %}(Hjemme){% else %}(Borte){% endif %}</span>
                    </span>
                    <span class="match-score">{{ m.score }}</span>
                    <span class="match-result">
                        {% if m.result == 'W' %}Seier{% elif m.result == 'D' %}Uavgjort{% else %}Tap{% endif %}
                    </span>
                </button>
                {% endfor %}
            </div>
            <p class="section-link"><a href="https://www.godset.no/resultater" target="_blank" rel="noopener">Se alle resultater på godset.no →</a></p>
        </section>

        {# Upcoming Matches #}
        <section class="section" id="kommende-kamper">
            <h2 class="section-title"><a href="#kommende-kamper">Kommende kamper</a></h2>
            <div class="matches-list">
                {% for m in upcoming_matches %}
                <div class="match-row match-upcoming">
                    <span class="match-date">{{ m.date[:10] }}</span>
                    <span class="match-teams">
                        {% if m.is_home %}{{ m.away_team }}{% else %}{{ m.home_team }}{% endif %}
                        <span class="match-venue">{% if m.is_home %}(Hjemme){% else %}(Borte){% endif %}</span>
                    </span>
                    <span class="match-round">Runde {{ m.round }}</span>
                </div>
                {% endfor %}
            </div>
            <p class="section-link"><a href="https://www.godset.no/terminliste" target="_blank" rel="noopener">Se alle kommende kamper på godset.no →</a></p>
        </section>

        {# Top Scorers #}
        {% if top_scorers %}
        <section class="section" id="toppscorer">
            <h2 class="section-title"><a href="#toppscorer">Målpoeng</a></h2>
            <div class="table-wrapper">
                <table class="league-table topscorer-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Spiller</th>
                            <th><span class="hide-mobile">Mål</span><span class="show-mobile">M</span></th>
                            <th><span class="hide-mobile">Assists</span><span class="show-mobile">A</span></th>
                            <th><span class="hide-mobile">Målpoeng</span><span class="show-mobile">MP</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for s in top_scorers %}
                        <tr>
                            <td class="pos">{{ loop.index }}</td>
                            <td class="team">{{ s.name }}</td>
                            <td>{{ s.goals }}</td>
                            <td>{{ s.assists }}</td>
                            <td class="points">{{ s.points }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
        {% endif %}

        {# Goal Timing #}
        {% if team.goal_timing and team.goal_timing.total > 0 %}
        <section class="section" id="maltidspunkt">
            <h2 class="section-title"><a href="#maltidspunkt">Når scores målene?</a></h2>
            <p class="section-intro">Fordeling av Godsets mål i 15-minuttersintervaller denne sesongen.</p>
            <h3 class="stats-category-title">1. omgang</h3>
            <div class="timing-chart">
                {% for interval in team.goal_timing.intervals[:3] %}
                <div class="timing-row">
                    <span class="timing-label">{{ interval.label }}</span>
                    <div class="timing-bar-bg">
                        <div class="timing-bar" style="width: {{ interval.percent }}%"></div>
                    </div>
                    <span class="timing-value">{{ interval.count }}{% if team.goal_timing.total > 0 %} <span class="timing-percent">({{ interval.percent }}%)</span>{% endif %}</span>
                </div>
                {% endfor %}
            </div>
            <h3 class="stats-category-title">2. omgang</h3>
            <div class="timing-chart">
                {% for interval in team.goal_timing.intervals[3:] %}
                <div class="timing-row">
                    <span class="timing-label">{{ interval.label }}</span>
                    <div class="timing-bar-bg">
                        <div class="timing-bar" style="width: {{ interval.percent }}%"></div>
                    </div>
                    <span class="timing-value">{{ interval.count }}{% if team.goal_timing.total > 0 %} <span class="timing-percent">({{ interval.percent }}%)</span>{% endif %}</span>
                </div>
                {% endfor %}
            </div>
            <p class="stats-note">Totalt {{ team.goal_timing.total }} mål</p>
        </section>
        {% endif %}

        {# Table #}
        <section class="section" id="tabell">
            <h2 class="section-title"><a href="#tabell">Tabell – OBOS-ligaen 2026</a></h2>
            <div class="table-wrapper">
                <table class="league-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Lag</th>
                            <th>K</th>
                            <th>V</th>
                            <th>U</th>
                            <th>T</th>
                            <th class="hide-mobile">+/-</th>
                            <th class="hide-mobile">MF</th>
                            <th>P</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for t in table %}
                        <tr class="{% if t.name == 'Strømsgodset' %}highlight{% endif %} {% if t.position <= 2 %}promotion{% elif t.position <= 6 %}qualification{% elif t.position == 14 %}relegation-playoff{% elif t.position >= 15 %}relegation{% endif %}">
                            <td class="pos">{{ t.position }}</td>
                            <td class="team">{{ t.display_name }}</td>
                            <td>{{ t.played }}</td>
                            <td>{{ t.won }}</td>
                            <td>{{ t.drawn }}</td>
                            <td>{{ t.lost }}</td>
                            <td class="hide-mobile">{{ t.goals_for }}–{{ t.goals_against }}</td>
                            <td class="hide-mobile">{{ t.goal_difference }}</td>
                            <td class="points">{{ t.points }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="legend">
                <span class="legend-item"><span class="legend-box promotion"></span> Direkte opprykk</span>
                <span class="legend-item"><span class="legend-box qualification"></span> Kvalifisering</span>
                <span class="legend-item"><span class="legend-box relegation-playoff"></span> Nedrykkskvalifisering</span>
                <span class="legend-item"><span class="legend-box relegation"></span> Nedrykk</span>
            </div>
            <p class="section-link"><a href="https://www.obos-ligaen.no/tabell" target="_blank" rel="noopener">Se offisiell tabell på obos-ligaen.no →</a></p>
        </section>
    </main>

    {% for category_key, category in team.ranks.items() %}
    {% for key, rank in category.stats.items() %}
    {% if rank.full_table %}
    <div class="modal" id="modal-{{ category_key }}-{{ key }}" role="dialog" aria-modal="true" aria-labelledby="modal-title-{{ category_key }}-{{ key }}" hidden>
        <div class="modal-backdrop" data-close-modal></div>
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="modal-title-{{ category_key }}-{{ key }}">{{ rank.label }} – hele ligaen</h3>
                <button class="modal-close" type="button" aria-label="Lukk" data-close-modal>&times;</button>
            </div>
            <div class="modal-body">
                <div class="table-wrapper">
                    <table class="league-table ranking-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Lag</th>
                                <th>{{ rank.label }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for row in rank.full_table %}
                            <tr class="{% if row.name == 'Strømsgodset' %}highlight{% endif %}">
                                <td class="pos">{{ row.rank }}</td>
                                <td class="team">{{ row.name }}</td>
                                <td class="points">{{ row.display_value }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
    {% endfor %}
    {% endfor %}

    {# Match detail modals #}
    {% for m in last_matches %}
    {% if m.stats %}
    <div class="modal" id="modal-match-{{ loop.index }}" role="dialog" aria-modal="true" aria-labelledby="modal-match-title-{{ loop.index }}" hidden>
        <div class="modal-backdrop" data-close-modal></div>
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="modal-match-title-{{ loop.index }}">
                    {{ m.home_team }} – {{ m.away_team }}
                </h3>
                <button class="modal-close" type="button" aria-label="Lukk" data-close-modal>&times;</button>
            </div>
            <div class="modal-body">
                <div class="match-modal-meta">
                    <span class="match-modal-date">{{ m.date[:10] }}</span>
                    <span class="match-modal-venue">{% if m.is_home %}Hjemme{% else %}Borte{% endif %}</span>
                    <span class="match-modal-result form-badge form-{{ m.result|lower }}">
                        {% if m.result == 'W' %}Seier{% elif m.result == 'D' %}Uavgjort{% else %}Tap{% endif %}
                    </span>
                </div>

                {% if m.home_score is not none and m.away_score is not none %}
                <div class="match-modal-scoreboard result-{{ m.result|lower }}">
                    <div class="match-modal-team match-modal-team-home">
                        <span class="match-modal-team-name">{{ m.home_team }}</span>
                        <span class="match-modal-team-label">Hjemme</span>
                        <span class="match-modal-team-score">{{ m.home_score }}</span>
                    </div>
                    <div class="match-modal-score-separator">–</div>
                    <div class="match-modal-team match-modal-team-away">
                        <span class="match-modal-team-name">{{ m.away_team }}</span>
                        <span class="match-modal-team-label">Borte</span>
                        <span class="match-modal-team-score">{{ m.away_score }}</span>
                    </div>
                </div>
                {% endif %}

                {% if m.stats.possession is not none or m.stats.total_shots is not none or m.stats.shots_on_goal is not none or m.stats.chances is not none %}
                <div class="match-modal-section">
                    <h4>Kampstatistikk</h4>
                    {% set home_possession = m.stats.possession if m.is_home else m.stats.opponent_possession %}
                    {% set away_possession = m.stats.opponent_possession if m.is_home else m.stats.possession %}
                    {% set home_shots = m.stats.total_shots if m.is_home else m.stats.opponent_total_shots %}
                    {% set away_shots = m.stats.opponent_total_shots if m.is_home else m.stats.total_shots %}
                    {% set home_sog = m.stats.shots_on_goal if m.is_home else m.stats.opponent_shots_on_goal %}
                    {% set away_sog = m.stats.opponent_shots_on_goal if m.is_home else m.stats.shots_on_goal %}
                    {% set home_chances = m.stats.chances if m.is_home else m.stats.opponent_chances %}
                    {% set away_chances = m.stats.opponent_chances if m.is_home else m.stats.chances %}
                    <div class="match-stat-compare">
                        <div class="match-stat-compare-header">
                            <span>{{ m.home_team }}</span>
                            <span></span>
                            <span>{{ m.away_team }}</span>
                        </div>
                        {% if home_possession is not none and away_possession is not none %}
                        <div class="match-stat-compare-row">
                            <span class="match-stat-home {% if home_possession > away_possession %}match-stat-best{% elif home_possession < away_possession %}match-stat-worst{% endif %}">{{ home_possession }}%</span>
                            <span class="match-stat-label">Ballbesittelse</span>
                            <span class="match-stat-away {% if away_possession > home_possession %}match-stat-best{% elif away_possession < home_possession %}match-stat-worst{% endif %}">{{ away_possession }}%</span>
                        </div>
                        {% endif %}
                        {% if home_shots is not none and away_shots is not none %}
                        <div class="match-stat-compare-row">
                            <span class="match-stat-home {% if home_shots > away_shots %}match-stat-best{% elif home_shots < away_shots %}match-stat-worst{% endif %}">{{ home_shots }}</span>
                            <span class="match-stat-label">Skudd</span>
                            <span class="match-stat-away {% if away_shots > home_shots %}match-stat-best{% elif away_shots < home_shots %}match-stat-worst{% endif %}">{{ away_shots }}</span>
                        </div>
                        {% endif %}
                        {% if home_sog is not none and away_sog is not none %}
                        <div class="match-stat-compare-row">
                            <span class="match-stat-home {% if home_sog > away_sog %}match-stat-best{% elif home_sog < away_sog %}match-stat-worst{% endif %}">{{ home_sog }}</span>
                            <span class="match-stat-label">Skudd på mål</span>
                            <span class="match-stat-away {% if away_sog > home_sog %}match-stat-best{% elif away_sog < home_sog %}match-stat-worst{% endif %}">{{ away_sog }}</span>
                        </div>
                        {% endif %}
                        {% if home_chances is not none and away_chances is not none %}
                        <div class="match-stat-compare-row">
                            <span class="match-stat-home {% if home_chances > away_chances %}match-stat-best{% elif home_chances < away_chances %}match-stat-worst{% endif %}">{{ home_chances }}</span>
                            <span class="match-stat-label">Sjanser</span>
                            <span class="match-stat-away {% if away_chances > home_chances %}match-stat-best{% elif away_chances < home_chances %}match-stat-worst{% endif %}">{{ away_chances }}</span>
                        </div>
                        {% endif %}
                    </div>
                </div>
                {% endif %}

                {% if m.stats.goalscorers %}
                <div class="match-modal-section">
                    <h4>Mål</h4>
                    {% set home_goals = m.stats.goalscorers | selectattr('team', 'equalto', m.home_team) | sort(attribute='minute') | list %}
                    {% set away_goals = m.stats.goalscorers | selectattr('team', 'equalto', m.away_team) | sort(attribute='minute') | list %}
                    <div class="match-modal-goals">
                        <div class="match-modal-goal-col">
                            <p class="match-modal-goal-col-title">{{ m.home_team }}</p>
                            {% if home_goals %}
                            <ul class="match-modal-list">
                                {%- for g in home_goals %}
                                {%- set ns = namespace(assist=None) %}
                                {%- for a in m.stats.assists %}
                                    {%- if a.team == g.team and a.minute == g.minute %}
                                        {%- set ns.assist = a.name %}
                                    {%- endif %}
                                {%- endfor %}
                                <li>{{ g.name }}{% if ns.assist %} ({{ ns.assist }}){% endif %} <span class="match-modal-minute">{{ g.minute }}'</span></li>
                                {%- endfor %}
                            </ul>
                            {% else %}
                            <span class="match-modal-no-goal">–</span>
                            {% endif %}
                        </div>
                        <div class="match-modal-goal-col">
                            <p class="match-modal-goal-col-title">{{ m.away_team }}</p>
                            {% if away_goals %}
                            <ul class="match-modal-list">
                                {%- for g in away_goals %}
                                {%- set ns = namespace(assist=None) %}
                                {%- for a in m.stats.assists %}
                                    {%- if a.team == g.team and a.minute == g.minute %}
                                        {%- set ns.assist = a.name %}
                                    {%- endif %}
                                {%- endfor %}
                                <li>{{ g.name }}{% if ns.assist %} ({{ ns.assist }}){% endif %} <span class="match-modal-minute">{{ g.minute }}'</span></li>
                                {%- endfor %}
                            </ul>
                            {% else %}
                            <span class="match-modal-no-goal">–</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
    {% endif %}
    {% endfor %}

