    <script>
    (function() {
        // Mobile nav toggle
        var toggle = document.querySelector('.nav-toggle');
        var menu = document.getElementById('nav-menu');
        if (toggle && menu) {
            toggle.addEventListener('click', function() {
                var expanded = toggle.getAttribute('aria-expanded') === 'true';
                toggle.setAttribute('aria-expanded', String(!expanded));
                menu.classList.toggle('is-open');
            });

            menu.querySelectorAll('a').forEach(function(link) {
                link.addEventListener('click', function() {
                    toggle.setAttribute('aria-expanded', 'false');
                    menu.classList.remove('is-open');
                });
            });
        }

        // Copy link button
        var copyBtn = document.getElementById('copy-link');
        if (copyBtn) {
            copyBtn.addEventListener('click', function() {
                var url = 'https://godset.mats.codes/';
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(url).then(function() {
                        copyBtn.setAttribute('title', 'Kopiert!');
                        setTimeout(function() {
                            copyBtn.setAttribute('title', 'Kopier lenke');
                        }, 1500);
                    });
                } else {
                    var ta = document.createElement('textarea');
                    ta.value = url;
                    ta.style.position = 'fixed';
                    ta.style.opacity = '0';
                    document.body.appendChild(ta);
                    ta.select();
                    try {
                        document.execCommand('copy');
                        copyBtn.setAttribute('title', 'Kopiert!');
                        setTimeout(function() {
                            copyBtn.setAttribute('title', 'Kopier lenke');
                        }, 1500);
                    } catch (e) {}
                    document.body.removeChild(ta);
                }
            });
        }

        // Tooltip tap-to-toggle / tap-outside-to-close
        document.querySelectorAll('.tooltip-trigger, .footer-tooltip-trigger').forEach(function(trigger) {
            trigger.addEventListener('click', function(e) {
                e.stopPropagation();
                var tooltip = trigger.querySelector('.tooltip-text');
                if (!tooltip) return;
                var isVisible = tooltip.classList.contains('is-visible');
                document.querySelectorAll('.tooltip-text.is-visible').forEach(function(t) {
                    t.classList.remove('is-visible');
                });
                if (!isVisible) {
                    tooltip.classList.add('is-visible');
                }
            });
        });

        document.addEventListener('click', function() {
            document.querySelectorAll('.tooltip-text.is-visible').forEach(function(t) {
                t.classList.remove('is-visible');
            });
        });

        // Stat rank modals
        document.querySelectorAll('.rank-btn').forEach(function(openBtn) {
            var modalId = openBtn.getAttribute('aria-controls');
            var modal = document.getElementById(modalId);
            if (!modal) return;
            var closeBtns = modal.querySelectorAll('[data-close-modal]');
            function doOpen() {
                modal.hidden = false;
                document.body.style.overflow = 'hidden';
                var closeBtn = modal.querySelector('.modal-close');
                if (closeBtn) closeBtn.focus();
            }
            function doClose() {
                modal.hidden = true;
                document.body.style.overflow = '';
                openBtn.focus();
            }
            openBtn.addEventListener('click', doOpen);
            closeBtns.forEach(function(btn) {
                btn.addEventListener('click', doClose);
            });
            var modalContent = modal.querySelector('.modal-content');
            if (modalContent) {
                modalContent.addEventListener('click', function(e) {
                    if (window.innerWidth <= 480) {
                        doClose();
                    }
                });
            }
        });

        // Match detail modals
        document.querySelectorAll('.match-btn').forEach(function(openBtn) {
            var modalId = openBtn.getAttribute('aria-controls');
            var modal = document.getElementById(modalId);
            if (!modal) return;
            var closeBtns = modal.querySelectorAll('[data-close-modal]');
            function doOpen() {
                modal.hidden = false;
                document.body.style.overflow = 'hidden';
                var closeBtn = modal.querySelector('.modal-close');
                if (closeBtn) closeBtn.focus();
            }
            function doClose() {
                modal.hidden = true;
                document.body.style.overflow = '';
                openBtn.focus();
            }
            openBtn.addEventListener('click', doOpen);
            closeBtns.forEach(function(btn) {
                btn.addEventListener('click', doClose);
            });
            var modalContent = modal.querySelector('.modal-content');
            if (modalContent) {
                modalContent.addEventListener('click', function(e) {
                    if (window.innerWidth <= 480) {
                        doClose();
                    }
                });
            }
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                var openModal = document.querySelector('.modal:not([hidden])');
                if (openModal) {
                    openModal.hidden = true;
                    document.body.style.overflow = '';
                    var btn = document.querySelector('[aria-controls="' + openModal.id + '"]');
                    if (btn) btn.focus();
                }
            }
        });
    })();
    </script>
