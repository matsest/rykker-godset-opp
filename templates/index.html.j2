<!DOCTYPE html>
<html lang="nb">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rykker Godset Opp? – Statistikk og tabell 2026</title>
    <meta name="description" content="Følg Strømsgodsets vei tilbake til Eliteserien. Se tabell, form, nøkkeltall, ligastatistikk og opprykksstatus i OBOS-ligaen 2026.">
    <meta name="keywords" content="Strømsgodset, Godset, OBOS-ligaen, opprykk, Eliteserien, tabell, fotball, 2026">
    <meta name="author" content="Mats Estensen">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://godset.mats.codes/">
    <link rel="icon" type="image/svg+xml" href="favicon.svg">
    <link rel="stylesheet" href="style.css">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://godset.mats.codes/">
    <meta property="og:title" content="Rykker Godset Opp? Følg Strømsgodsets vei tilbake til Eliteserien.">
    <meta property="og:description" content="Oppdatert nøkkeltall, opprykksstatus og tabell for Strømsgodset i 2026.">
    <meta property="og:locale" content="nb_NO">
    <meta property="og:image" content="https://godset.mats.codes/og-image.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@matsest">
    <meta name="twitter:creator" content="@matsest">
    <meta name="twitter:url" content="https://godset.mats.codes/">
    <meta name="twitter:title" content="Rykker Godset Opp? Følg Strømsgodsets vei tilbake til Eliteserien.">
    <meta name="twitter:description" content="Oppdatert nøkkeltall, opprykksstatus og tabell for Strømsgodset i 2026.">
    <meta name="twitter:image" content="https://godset.mats.codes/og-image.png">

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Rykker Godset Opp?",
        "url": "https://godset.mats.codes/",
        "description": "Følg Strømsgodsets vei tilbake til Eliteserien. Oppdatert statistikk, opprykksstatus, tabell, form og kommende kamper i OBOS-ligaen 2026.",
        "inLanguage": "nb",
        "publisher": {
            "@type": "Person",
            "name": "Mats Estensen",
            "url": "https://github.com/matsest"
        }
    }
    </script>
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "SportsTeam",
        "name": "Strømsgodset",
        "alternateName": "Godset",
        "sport": "Association Football",
        "foundingDate": "1907-02-10",
        "location": {
            "@type": "Place",
            "name": "Drammen",
            "address": {
                "@type": "PostalAddress",
                "addressLocality": "Drammen",
                "addressCountry": "NO"
            }
        },
        "memberOf": {
            "@type": "SportsOrganization",
            "name": "OBOS-ligaen",
            "alternateName": "1. divisjon",
            "sport": "Association Football"
        },
        "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "{{ godset.points_per_game }}",
            "bestRating": "3",
            "worstRating": "0"
        }
    }
    </script>
</head>
<body>
    <header class="site-header">
        <div class="container">
            <h1 class="site-title">Rykker Godset Opp?</h1>
            <p class="site-subtitle">Følg Strømsgodsets vei tilbake til Eliteserien.<br>Se tabell, form, nøkkeltall og opprykksstatus fra OBOS-ligaen 2026.</p>
        </div>
    </header>

    <nav class="site-nav" aria-label="Seksjoner">
        <div class="nav-inner">
            <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" type="button">
                <span class="sr-only">Meny</span>
                <svg class="icon-menu" viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                    <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <line x1="3" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <line x1="3" y1="18" x2="21" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <svg class="icon-close" viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
                    <line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <line x1="6" y1="18" x2="18" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </button>
            <div class="nav-menu" id="nav-menu">
                <a href="#nokkeltall">Nøkkeltall</a>
                <a href="#opprykksstatus">Opprykksstatus</a>
                <a href="#ligastatistikk">Ligastatistikk</a>
                <a href="#form">Form</a>
                <a href="#siste-resultater">Resultater</a>
                <a href="#kommende-kamper">Kamper</a>
                <a href="#tabell">Tabell</a>
            </div>
        </div>
    </nav>

    <main class="container">
        {# Hero: The Gauge #}
        <section class="hero">
            <div class="gauge">
                <div class="gauge-bar">
                    <div class="gauge-needle" style="left: {{ godset.promotion.gauge_percent }}%"></div>
                </div>
                <div class="gauge-labels">
                    <span>Nei</span>
                    <span>Tja</span>
                    <span>Ja!</span>
                </div>
            </div>
            <div class="hero-stats">
                <div class="hero-stat">
                    <span class="hero-stat-value">{{ godset.position }}.</span>
                    <span class="hero-stat-label">Plassering</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-value">{{ godset.points }}</span>
                    <span class="hero-stat-label">Poeng</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-value">{{ godset.played }}</span>
                    <span class="hero-stat-label">Kamper</span>
                </div>
            </div>
        </section>

        {# Key Numbers #}
        <section class="section" id="nokkeltall">
            <h2 class="section-title"><a href="#nokkeltall">Nøkkeltall</a></h2>
            <div class="stats-grid">
                <div class="stat-card {% if godset.played > 0 %}{% set win_pct = (godset.won / godset.played * 100) %}{% if win_pct >= 50 %}stat-positive{% elif win_pct >= 30 %}stat-warning{% else %}stat-negative{% endif %}{% endif %}">
                    <span class="stat-value">{{ godset.won }}-{{ godset.drawn }}-{{ godset.lost }}</span>
                    <span class="stat-label">
                        Seire – Uavgjort – Tap
                        <span class="tooltip-trigger" tabindex="0">&#9432;
                            <span class="tooltip-text">Grønn: ≥50% seier, Gul: ≥30% seier, Rød: &lt;30% seier</span>
                        </span>
                    </span>
                </div>
                <div class="stat-card {% if godset.played > 0 %}{% set win_pct = (godset.won / godset.played * 100) %}{% if win_pct >= 50 %}stat-positive{% elif win_pct >= 30 %}stat-warning{% else %}stat-negative{% endif %}{% endif %}">
                    <span class="stat-value">{% if godset.played > 0 %}{{ (godset.won / godset.played * 100)|round|int }}%{% else %}0%{% endif %}</span>
                    <span class="stat-label">
                        Seiersprosent
                        <span class="tooltip-trigger" tabindex="0">&#9432;
                            <span class="tooltip-text">Grønn: ≥50% seier, Gul: ≥30% seier, Rød: &lt;30% seier</span>
                        </span>
                    </span>
                </div>
                <div class="stat-card {% if godset.played > 0 %}{% set gd_per_game = godset.goal_difference / godset.played %}{% if gd_per_game >= 0.5 %}stat-positive{% elif godset.goal_difference >= 0 %}stat-warning{% else %}stat-negative{% endif %}{% endif %}">
                    <span class="stat-value">{% if godset.goal_difference > 0 %}+{% endif %}{{ godset.goal_difference|default(0, true) }}</span>
                    <span class="stat-label">
                        Målforskjell
                        <span class="tooltip-trigger" tabindex="0">&#9432;
                            <span class="tooltip-text">Grønn: ≥+0,5 per kamp, Gul: ≥0, Rød: Negativ</span>
                        </span>
                    </span>
                </div>
                <div class="stat-card {% if godset.points_per_game >= 2.0 %}stat-positive{% elif godset.points_per_game >= 1.8 %}stat-warning{% else %}stat-negative{% endif %}">
                    <span class="stat-value">{{ godset.points_per_game }}</span>
                    <span class="stat-label">
                        Poengsnitt per kamp
                        <span class="tooltip-trigger" tabindex="0">&#9432;
                            <span class="tooltip-text">Grønn: ≥2,0, Gul: ≥1,8, Rød: &lt;1,8</span>
                        </span>
                    </span>
                </div>
                <div class="stat-card {% if godset.home.avg >= 2.0 %}stat-positive{% elif godset.home.avg >= 1.8 %}stat-warning{% else %}stat-negative{% endif %}">
                    <span class="stat-value">{{ godset.home.avg }}</span>
                    <span class="stat-label">
                        Poengsnitt hjemme
                        <span class="tooltip-trigger" tabindex="0">&#9432;
                            <span class="tooltip-text">Grønn: ≥2,0, Gul: ≥1,8, Rød: &lt;1,8</span>
                        </span>
                    </span>
                </div>
                <div class="stat-card {% if godset.away.avg >= 2.0 %}stat-positive{% elif godset.away.avg >= 1.8 %}stat-warning{% else %}stat-negative{% endif %}">
                    <span class="stat-value">{{ godset.away.avg }}</span>
                    <span class="stat-label">
                        Poengsnitt borte
                        <span class="tooltip-trigger" tabindex="0">&#9432;
                            <span class="tooltip-text">Grønn: ≥2,0, Gul: ≥1,8, Rød: &lt;1,8</span>
                        </span>
                    </span>
                </div>
            </div>
        </section>

        {# Promotion Status #}
        <section class="section" id="opprykksstatus">
            <h2 class="section-title"><a href="#opprykksstatus">Opprykksstatus</a></h2>
            <div class="promo-grid promo-grid-3">
                <div class="promo-item {% set diff_1st = -godset.promotion.points_to_1st %}{% if diff_1st >= 0 %}promo-positive{% elif diff_1st >= -3 %}promo-warning{% else %}promo-negative{% endif %}">
                    <span class="promo-value">{% set diff_1st = -godset.promotion.points_to_1st %}{% if diff_1st > 0 %}+{% endif %}{{ diff_1st }}</span>
                    <span class="promo-label">Poeng unna 1. plass</span>
                </div>
                <div class="promo-item {% set diff_2nd = -godset.promotion.points_to_2nd %}{% if diff_2nd >= 0 %}promo-positive{% elif diff_2nd >= -3 %}promo-warning{% else %}promo-negative{% endif %}">
                    <span class="promo-value">{% set diff_2nd = -godset.promotion.points_to_2nd %}{% if diff_2nd > 0 %}+{% endif %}{{ diff_2nd }}</span>
                    <span class="promo-label">Poeng unna 2. plass</span>
                </div>
                <div class="promo-item {% set diff_6th = -godset.promotion.points_to_6th %}{% if diff_6th >= 0 %}promo-positive{% elif diff_6th >= -3 %}promo-warning{% else %}promo-negative{% endif %}">
                    <span class="promo-value">{% set diff_6th = -godset.promotion.points_to_6th %}{% if diff_6th > 0 %}+{% endif %}{{ diff_6th }}</span>
                    <span class="promo-label">Poeng unna 6. plass (kvalik)</span>
                </div>
            </div>
        </section>

        {# League Stats #}
        {% if godset.ranks %}
        <section class="section" id="ligastatistikk">
            <h2 class="section-title"><a href="#ligastatistikk">Ligastatistikk</a></h2>
            <div class="stats-grid">
                {% for key, rank in godset.ranks.items() %}
                <div class="stat-card {% if rank.vs_table == 'better' %}stat-positive{% elif rank.vs_table == 'worse' %}stat-negative{% else %}stat-warning{% endif %}">
                    <span class="stat-value">{{ rank.display_value }}</span>
                    <span class="stat-label">
                        {{ rank.label }}
                        {% if key == 'conversion_rate' %}
                        <span class="tooltip-trigger" tabindex="0" aria-label="Hva er målprosent?">&#9432;
                            <span class="tooltip-text">Andel av skudd på mål som ender i mål</span>
                        </span>
                        {% elif key == 'points_last_5' %}
                        <span class="tooltip-trigger" tabindex="0" aria-label="Hva er form?">&#9432;
                            <span class="tooltip-text">Poeng fra de siste 5 kampene (maks 15 poeng)</span>
                        </span>
                        {% endif %}
                    </span>
                    <span class="stat-rank">
                        {{ rank.display_rank }}
                        <span class="rank-indicator {% if rank.vs_table == 'better' %}ind-better{% elif rank.vs_table == 'worse' %}ind-worse{% else %}ind-equal{% endif %}">
                            {% if rank.vs_table == 'better' %}↑{% elif rank.vs_table == 'worse' %}↓{% else %}→{% endif %}
                        </span>
                    </span>
                </div>
                {% endfor %}
            </div>
        </section>
        {% endif %}

        {# Form #}
        <section class="section" id="form">
            <h2 class="section-title"><a href="#form">Form siste {{ godset.form_last_5|length }} kamper</a></h2>
            <div class="stats-grid">
                <div class="stat-card {% if godset.won_last_5 >= 3 %}stat-positive{% elif godset.won_last_5 >= 1 %}stat-warning{% else %}stat-negative{% endif %}">
                    <span class="stat-value">{{ godset.won_last_5 }}-{{ godset.drawn_last_5 }}-{{ godset.lost_last_5 }}</span>
                    <span class="stat-label">Seire – Uavgjort – Tap</span>
                </div>
                <div class="stat-card {% if godset.points_avg_last_5 >= 2.0 %}stat-positive{% elif godset.points_avg_last_5 >= 1.8 %}stat-warning{% else %}stat-negative{% endif %}">
                    <span class="stat-value">{{ godset.points_avg_last_5 }}</span>
                    <span class="stat-label">Poengsnitt (siste {{ last_matches|length }})</span>
                </div>
                <div class="stat-card {% if godset.goal_difference_last_5 > 0 %}stat-positive{% elif godset.goal_difference_last_5 == 0 %}stat-warning{% else %}stat-negative{% endif %}">
                    <span class="stat-value">{% if godset.goal_difference_last_5 > 0 %}+{% endif %}{{ godset.goal_difference_last_5|default(0, true) }}</span>
                    <span class="stat-label">Målforskjell (siste {{ last_matches|length }})</span>
                </div>
            </div>
            <div class="form-row">
                {% for r in godset.form_last_5 %}
                <span class="form-badge form-{{ r|lower }}">
                    {% if r == 'W' %}V{% elif r == 'D' %}U{% else %}T{% endif %}
                </span>
                {% endfor %}
            </div>
            <p class="form-points">{{ godset.points_last_5 }} poeng av 15 mulige</p>
        </section>

        {# Last Matches #}
        <section class="section" id="siste-resultater">
            <h2 class="section-title"><a href="#siste-resultater">Siste resultater</a></h2>
            <div class="matches-list">
                {% for m in last_matches %}
                <div class="match-row match-{{ m.result|lower }}">
                    <span class="match-date">{{ m.date[:10] }}</span>
                    <span class="match-teams">{{ m.home_team }} – {{ m.away_team }}</span>
                    <span class="match-score">{{ m.score }}</span>
                    <span class="match-result">
                        {% if m.result == 'W' %}Seier{% elif m.result == 'D' %}Uavgjort{% else %}Tap{% endif %}
                    </span>
                </div>
                {% endfor %}
            </div>
            <p class="section-link"><a href="https://www.godset.no/resultater" target="_blank" rel="noopener">Se alle resultater på godset.no →</a></p>
        </section>

        {# Upcoming Matches #}
        <section class="section" id="kommende-kamper">
            <h2 class="section-title"><a href="#kommende-kamper">Kommende kamper</a></h2>
            <div class="matches-list">
                {% for m in upcoming_matches %}
                <div class="match-row match-upcoming">
                    <span class="match-date">{{ m.date[:10] }}</span>
                    <span class="match-teams">{{ m.home_team }} – {{ m.away_team }}</span>
                    <span class="match-round">Runde {{ m.round }}</span>
                </div>
                {% endfor %}
            </div>
            <p class="section-link"><a href="https://www.godset.no/terminliste" target="_blank" rel="noopener">Se alle kommende kamper på godset.no →</a></p>
        </section>

        {# Table #}
        <section class="section" id="tabell">
            <h2 class="section-title"><a href="#tabell">Tabell – OBOS-ligaen 2026</a></h2>
            <div class="table-wrapper">
                <table class="league-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Lag</th>
                            <th>K</th>
                            <th>V</th>
                            <th>U</th>
                            <th>T</th>
                            <th class="hide-mobile">+/-</th>
                            <th class="hide-mobile">MF</th>
                            <th>P</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for t in table %}
                        <tr class="{% if t.name == 'Strømsgodset' %}highlight{% endif %} {% if t.position <= 2 %}promotion{% elif t.position <= 6 %}qualification{% elif t.position == 14 %}relegation-playoff{% elif t.position >= 15 %}relegation{% endif %}">
                            <td class="pos">{{ t.position }}</td>
                            <td class="team">{{ t.display_name }}</td>
                            <td>{{ t.played }}</td>
                            <td>{{ t.won }}</td>
                            <td>{{ t.drawn }}</td>
                            <td>{{ t.lost }}</td>
                            <td class="hide-mobile">{{ t.goals_for }}–{{ t.goals_against }}</td>
                            <td class="hide-mobile">{{ t.goal_difference }}</td>
                            <td class="points">{{ t.points }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="legend">
                <span class="legend-item"><span class="legend-box promotion"></span> Direkte opprykk</span>
                <span class="legend-item"><span class="legend-box qualification"></span> Kvalifisering</span>
                <span class="legend-item"><span class="legend-box relegation-playoff"></span> Nedrykkskvalifisering</span>
                <span class="legend-item"><span class="legend-box relegation"></span> Nedrykk</span>
            </div>
            <p class="section-link"><a href="https://www.obos-ligaen.no/tabell" target="_blank" rel="noopener">Se offisiell tabell på obos-ligaen.no →</a></p>
        </section>
    </main>

    <footer class="site-footer">
        <div class="container">
            <p><a href="https://github.com/matsest/rykker-godset-opp/actions/workflows/update-site.yml" target="_blank" rel="noopener">Sist oppdatert: {{ generated_at[:10] }} {{ generated_at[11:16] }} UTC</a> · Data fra <a href="https://www.nifs.no/" target="_blank" rel="noopener">NIFS</a></p>
            <div class="footer-actions">
                <span class="footer-actions-label">Del siden:</span>
                <a class="action-btn" href="https://twitter.com/intent/tweet?url=https%3A%2F%2Fgodset.mats.codes%2F&amp;text=Rykker%20Godset%20Opp%3F%20Følg%20Strømsgodsets%20vei%20tilbake%20til%20Eliteserien." target="_blank" rel="noopener" aria-label="Del på X" title="Del på X">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
                <a class="action-btn" href="https://bsky.app/intent/compose?text=Rykker%20Godset%20Opp%3F%20https%3A%2F%2Fgodset.mats.codes%2F" target="_blank" rel="noopener" aria-label="Del på Bluesky" title="Del på Bluesky">
                    <svg viewBox="0 0 64 57" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M13.873 3.805C21.21 9.332 29.103 20.537 32 26.55v15.882c0-.338-.13.044-.41.867-1.512 4.456-7.418 21.847-20.923 7.944-7.111-7.32-3.819-14.64 9.125-16.85-7.405 1.264-15.73-.825-18.014-9.015C1.12 23.022 0 8.51 0 6.55 0-3.268 8.579-.182 13.873 3.805ZM50.127 3.805C42.79 9.332 34.897 20.537 32 26.55v15.882c0-.338.13.044.41.867 1.512 4.456 7.418 21.847 20.923 7.944 7.111-7.32 3.819-14.64-9.125-16.85 7.405 1.264 15.73-.825 18.014-9.015C62.88 23.022 64 8.51 64 6.55c0-9.818-8.578-6.732-13.873-2.745Z"/></svg>
                </a>
                <a class="action-btn" href="https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Fgodset.mats.codes%2F" target="_blank" rel="noopener" aria-label="Del på Facebook" title="Del på Facebook">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a class="action-btn" href="https://www.linkedin.com/sharing/share-offsite/?url=https%3A%2F%2Fgodset.mats.codes%2F" target="_blank" rel="noopener" aria-label="Del på LinkedIn" title="Del på LinkedIn">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
                <button class="action-btn" id="copy-link" type="button" aria-label="Kopier lenke" title="Kopier lenke">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                </button>
            </div>
            <p class="footer-note">Bygget med ekte kjærlighet 💙 og <a href="https://github.com/matsest/rykker-godset-opp" target="_blank" rel="noopener">åpen kildekode</a> av <a href="https://github.com/matsest" target="_blank" rel="noopener">Mats Estensen</a> · Kontakt: <a href="mailto:contact@mxe.no">contact@mxe.no</a></p>
        </div>
    </footer>
    <script>
    (function() {
        // Mobile nav toggle
        var toggle = document.querySelector('.nav-toggle');
        var menu = document.getElementById('nav-menu');
        if (toggle && menu) {
            toggle.addEventListener('click', function() {
                var expanded = toggle.getAttribute('aria-expanded') === 'true';
                toggle.setAttribute('aria-expanded', String(!expanded));
                menu.classList.toggle('is-open');
            });

            menu.querySelectorAll('a').forEach(function(link) {
                link.addEventListener('click', function() {
                    toggle.setAttribute('aria-expanded', 'false');
                    menu.classList.remove('is-open');
                });
            });
        }

        // Copy link button
        var copyBtn = document.getElementById('copy-link');
        if (copyBtn) {
            copyBtn.addEventListener('click', function() {
                var url = 'https://godset.mats.codes/';
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(url).then(function() {
                        copyBtn.setAttribute('title', 'Kopiert!');
                        setTimeout(function() {
                            copyBtn.setAttribute('title', 'Kopier lenke');
                        }, 1500);
                    });
                } else {
                    var ta = document.createElement('textarea');
                    ta.value = url;
                    ta.style.position = 'fixed';
                    ta.style.opacity = '0';
                    document.body.appendChild(ta);
                    ta.select();
                    try {
                        document.execCommand('copy');
                        copyBtn.setAttribute('title', 'Kopiert!');
                        setTimeout(function() {
                            copyBtn.setAttribute('title', 'Kopier lenke');
                        }, 1500);
                    } catch (e) {}
                    document.body.removeChild(ta);
                }
            });
        }

        // Tooltip tap-to-toggle / tap-outside-to-close
        document.querySelectorAll('.tooltip-trigger').forEach(function(trigger) {
            trigger.addEventListener('click', function(e) {
                e.stopPropagation();
                var tooltip = trigger.querySelector('.tooltip-text');
                if (!tooltip) return;
                var isVisible = tooltip.classList.contains('is-visible');
                document.querySelectorAll('.tooltip-text.is-visible').forEach(function(t) {
                    t.classList.remove('is-visible');
                });
                if (!isVisible) {
                    tooltip.classList.add('is-visible');
                }
            });
        });

        document.addEventListener('click', function() {
            document.querySelectorAll('.tooltip-text.is-visible').forEach(function(t) {
                t.classList.remove('is-visible');
            });
        });
    })();
    </script>
</body>
</html>
